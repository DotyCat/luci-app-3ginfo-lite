AMBR_QCI=$(echo "$AMBR_RAW" | cut -d, -f2)
AMBR_DL=$(echo "$AMBR_RAW" | cut -d, -f7)
AMBR_UL=$(echo "$AMBR_RAW" | cut -d, -f8)
if [ -n "$AMBR_QCI" ] && [ -n "$AMBR_DL" ] && [ -n "$AMBR_UL" ]; then
	AMBR="DL: $(format_ambr_rate "$AMBR_DL") UL:$(format_ambr_rate "$AMBR_UL") QCI:$AMBR_QCI"
else
