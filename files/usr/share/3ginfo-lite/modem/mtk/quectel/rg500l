modulation2str() {
# see https://en.wikipedia.org/wiki/5G_NR_frequency_bands
	case "${1}" in
		"0") echo "BPSK";;
		"1") echo "QPSK";;
		"2") echo "16QAM";;
		"3") echo "64QAM";;
		"4") echo "256QAM";;
		"*") echo "";;
	esac
}

bandwidth5g() {
	case "${1}" in
		"0") echo "5";;
		"1") echo "10";;
		"2") echo "15";;
		"3") echo "20";;
		"4") echo "25";;
		"5") echo "30";;
		"6") echo "40";;
		"7") echo "50";;
		"8") echo "60";;
		"9") echo "80";;
		"10") echo "90";;
		"11") echo "100";;
		"12") echo "200";;
		"13") echo "400";;
		"14") echo "70";;
		"*") echo "";;
	esac
}

bandwidth4g() {
	case "${1}" in
		"0") echo "1.4";;
		"1") echo "3";;
		"2") echo "5";;
		"3") echo "10";;
		"4") echo "15";;
		"5") echo "20";;
		"*") echo "";;
	esac
}

