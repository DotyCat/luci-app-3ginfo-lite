format_ambr_rate() {
	case "$1" in
		''|*[!0-9]*)
			echo "-"
			return
		;;
	esac

	if [ "$1" -gt 10240 ]; then
		awk -v rate="$1" 'BEGIN { value = rate / 1024; if (value == int(value)) printf "%d Mbps", value; else printf "%.2f Mbps", value }'
	else
		echo "$1 Kbps"
	fi
}

