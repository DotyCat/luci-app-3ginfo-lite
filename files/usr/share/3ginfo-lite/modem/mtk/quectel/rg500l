				eval "json_get_var s${id}_ssb_rsrp_rx1 ssb_rsrp_rx1"
				eval "json_get_var s${id}_ssb_rsrp_rx2 ssb_rsrp_rx2"
				eval "json_get_var s${id}_ssb_rsrp_rx3 ssb_rsrp_rx3"
				eval "json_get_var s${id}_ssb_sinr_rx0 ssb_snr_rx0"
				eval "json_get_var s${id}_ssb_sinr_rx1 ssb_snr_rx1"
				eval "json_get_var s${id}_ssb_sinr_rx2 ssb_snr_rx2"
				eval "json_get_var s${id}_ssb_sinr_rx3 ssb_snr_rx3"
				eval "trs_rsrp_value=\$s${id}_trs_rsrp_rx0"
				eval "ssb_rsrp_value=\$s${id}_ssb_rsrp_rx0"
				eval "S${id}RSSI=\"\$s${id}_rssi_rx0 dBm | \$s${id}_rssi_rx1 dBm | \$s${id}_rssi_rx2 dBm | \$s${id}_rssi_rx3 dBm\""
				if [[ "$trs_rsrp_value" != "-255" && "$trs_rsrp_value" != "0" && "$trs_rsrp_value" != "" ]]; then
					eval "S${id}RSRP=\"\$s${id}_trs_rsrp_rx0 dBm | \$s${id}_trs_rsrp_rx1 dBm | \$s${id}_trs_rsrp_rx2 dBm | \$s${id}_trs_rsrp_rx3 dBm\""
					eval "S${id}SINR=\"\$s${id}_trs_sinr_rx0 dB | \$s${id}_trs_sinr_rx1 dB | \$s${id}_trs_sinr_rx2 dB | \$s${id}_trs_sinr_rx3 dB\""
				elif [[ "$ssb_rsrp_value" != "-255" && "$ssb_rsrp_value" != "0" && "$ssb_rsrp_value" != "" ]]; then
					eval "S${id}RSRP=\"\$s${id}_ssb_rsrp_rx0 dBm | \$s${id}_ssb_rsrp_rx1 dBm | \$s${id}_ssb_rsrp_rx2 dBm | \$s${id}_ssb_rsrp_rx3 dBm\""
					eval "S${id}SINR=\"\$s${id}_ssb_sinr_rx0 dB | \$s${id}_ssb_sinr_rx1 dB | \$s${id}_ssb_sinr_rx2 dB | \$s${id}_ssb_sinr_rx3 dB\""
				else
					eval "S${id}RSRP=\"\""
					eval "S${id}SINR=\"\""
				fi
			fi
			json_select ..
			idx=$((idx + 1))
			id=$((id + 1))
		done
		json_select ..
	fi
	json_select "lte_info"
	json_select "1"
	json_get_var lte_cc_num lte_cc_num
	if json_is_a "lte_cc_info" array; then
		json_select "lte_cc_info"
		id=1
		idx=1
		while json_is_a "$idx" object; do
			json_select "$idx"
			json_get_var lte_cc_type lte_cc_type
			known_cc_num=$nr_cc_num+$id
			if [ "$lte_cc_type" = "LTE PCC" ]; then
				json_get_var prssi_rx0 rssi_rx0
				json_get_var prssi_rx1 rssi_rx1
				json_get_var prssi_rx2 rssi_rx2
				json_get_var prssi_rx3 rssi_rx3
				json_get_var prsrp_rx0 rsrp_rx0
				json_get_var prsrp_rx1 rsrp_rx1
				json_get_var prsrp_rx2 rsrp_rx2
				json_get_var prsrp_rx3 rsrp_rx3
				json_get_var psinr_rx0 snr_rx0
				json_get_var psinr_rx1 snr_rx1
				json_get_var psinr_rx2 snr_rx2
				json_get_var psinr_rx3 snr_rx3
				PRSSI="$prssi_rx0 dBm | $prssi_rx1 dBm | $prssi_rx2 dBm | $prssi_rx3 dBm"
				PRSRP="$prsrp_rx0 dBm | $prsrp_rx1 dBm | $prsrp_rx2 dBm | $prsrp_rx3 dBm"
				PSINR="$psinr_rx0 dB | $psinr_rx1 dB | $psinr_rx2 dB | $psinr_rx3 dB"
			elif [[ "$lte_cc_type" == *"LTE SCC"* ]]; then
				eval "json_get_var s${known_cc_num}_rssi_rx0 rssi_rx0"
				eval "json_get_var s${known_cc_num}_rssi_rx1 rssi_rx1"
				eval "json_get_var s${known_cc_num}_rssi_rx2 rssi_rx2"
				eval "json_get_var s${known_cc_num}_rssi_rx3 rssi_rx3"
				eval "json_get_var s${known_cc_num}_rsrp_rx0 rsrp_rx0"
				eval "json_get_var s${known_cc_num}_rsrp_rx1 rsrp_rx1"
				eval "json_get_var s${known_cc_num}_rsrp_rx2 rsrp_rx2"
				eval "json_get_var s${known_cc_num}_rsrp_rx3 rsrp_rx3"
				eval "json_get_var s${known_cc_num}_sinr_rx0 sinr_rx0"
				eval "json_get_var s${known_cc_num}_sinr_rx1 sinr_rx1"
				eval "json_get_var s${known_cc_num}_sinr_rx2 sinr_rx2"
				eval "json_get_var s${known_cc_num}_sinr_rx3 sinr_rx3"
				eval "S${known_cc_num}RSSI=\"\$s${known_cc_num}_rssi_rx0 dBm | \$s${known_cc_num}_rssi_rx1 dBm | \$s${known_cc_num}_rssi_rx2 dBm | \$s${known_cc_num}_rssi_rx3 dBm\""
				eval "S${known_cc_num}RSRP=\"\$s${known_cc_num}_rsrp_rx0 dBm | \$s${known_cc_num}_rsrp_rx1 dBm | \$s${known_cc_num}_rsrp_rx2 dBm | \$s${known_cc_num}_rsrp_rx3 dBm\""
				eval "S${known_cc_num}SINR=\"\$s${known_cc_num}_sinr_rx0 dB | \$s${known_cc_num}_sinr_rx1 dB | \$s${known_cc_num}_sinr_rx2 dB | \$s${known_cc_num}_sinr_rx3 dB\""
			fi
			json_select ..
			idx=$((idx + 1))
			id=$((id + 1))
		done
		json_select ..
	fi
fi

